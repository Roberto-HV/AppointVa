# ── Base de datos ─────────────────────────────────────────────────────────────
DB_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera una clave en: https://randomkeygen.com (elige "256-bit WEP Keys")
JWT_CLAVE=REEMPLAZAR_CON_CLAVE_SECRETA_MINIMO_32_CARACTERES

# ── Cloudinary (imágenes) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=REEMPLAZAR
CLOUDINARY_API_KEY=REEMPLAZAR
CLOUDINARY_API_SECRET=REEMPLAZAR

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_REEMPLAZAR

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://appointva.com
BACKEND_URL=https://api.appointva.com

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGENES=https://appointva.com
